# Database (asyncpg driver). In docker-compose the host is "db".
DATABASE_URL=postgresql+asyncpg://flowea:flowea@db:5432/flowea_cmms

# Auth — generate a strong secret for production: openssl rand -hex 32
JWT_SECRET=change-me-in-production
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=14

# Front-end origins allowed to call the API (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Seed demo data on first boot (set false in production)
SEED_DEMO=true

# Object storage for photos/videos (optional). Leave blank to disable uploads.
# Cloudflare R2 example:
# S3_ENDPOINT_URL=https://<account>.r2.cloudflarestorage.com
# S3_BUCKET=flowea-media
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_REGION=auto
